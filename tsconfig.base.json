{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@thehundred/domain": [
        "packages/domain/src/index.ts"
      ],
      "@thehundred/db": [
        "packages/db/src/index.ts"
      ],
      "@thehundred/discord": [
        "packages/discord/src/index.ts"
      ],
      "@thehundred/killboard": [
        "packages/killboard/src/index.ts"
      ]
    }
  }
}

